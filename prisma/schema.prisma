// Configuração do banco (ajuste conforme seu .env)
datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
}

model Participantes {
    id        Int      @id @default(autoincrement())
    nome      String
    curso     String
    curse     String
    foto      String
    idade     String
    age       String
    email     String   @unique
    createdAt DateTime @default(now())
}

model Livro {
    id                   Int      @id @default(autoincrement())
    titulo               String
    capa                 String
    autor                String
    anoPublicacao        Int
    detalhesAutor_pt     String   
    detalhesAutor_en     String
    verossimilhanca_pt   String  
    verossimilhanca_en   String  
    genero_pt            String
    genero_en            String
    resumo_pt            String   @db.Text
    resumo_en            String   @db.Text
    personagens          Personagem[]
    contextoHistorico_pt String
    contextoHistorico_en String
    analise_pt           String
    analise_en           String
}

model Personagem {
    id                   Int    @id @default(autoincrement())
    nome                 String
    caracteristicas_pt   String
    caracteristicas_en   String
    representacao_pt     String
    representacao_en     String

    livroId              Int
    livro                Livro  @relation(fields: [livroId], references: [id])      
}

// 3. Tabela de Vídeo Aula
model VideoAula {
    id          Int    @id @default(autoincrement())
    conteudo    String
    content     String
    urlMidia    String
    descricao   String
    description String
}

model Curiosidade {
    id          Int    @id @default(autoincrement())
    conteudo    String
    content     String
    curiosidade String
    curiosity   String
}

model Dicas {
    id       Int    @id @default(autoincrement())
    conteudo String
    content  String
    dicas    String
    tips     String
}

model Simulado {
    id              Int    @id @default(autoincrement())
    pergunta        String
    question        String
    opcaoA          String
    optionA         String
    opcaoB          String
    optionB         String
    opcaoC          String
    optionC         String
    opcaoD          String
    optionD         String
    opcaoE          String
    optionE         String
    respostaCorreta String
    correctAnswer   String
    explicacao      String
    explanation     String
}

