// Configuração do banco (ajuste conforme seu .env)
datasource db {
    provider = "postgresql"
}

generator client {
    provider = "prisma-client-js"
}

model Participantes {
    id        Int      @id @default(autoincrement())
    nome      String
    curso     String
    curse     String
    foto      String
    idade     String
    age       String
    email     String   @unique
    createdAt DateTime @default(now())
}

model Livro {
  id                            Int      @id @default(autoincrement())
  titulo                        String
  capa                          String
  autor                         String
  detalhesAutor                 String
  detalhesAutor_en              String
  anoPublicacao                 Int
  genero                        String
  genero_en                     String
  resumo                        String   @db.Text
  resumo_en                     String   @db.Text
  contexto                      String   @db.Text
  contexto_en                   String   @db.Text
  estiloEscrita                 String   @db.Text
  estiloEscrita_en              String   @db.Text
  enredo                        String   @db.Text
  enredo_en                     String   @db.Text
  verossimilhanca               String   @db.Text
  verossimilhanca_en            String   @db.Text
  personagens                   String[]
  caracteristicasLiterarias     String   @db.Text
  caracteristicasLiterarias_en  String   @db.Text
  conclusao                     String   @db.Text
  conclusao_en                  String   @db.Text
}

model Personagem {
    id                   Int    @id @default(autoincrement())
    nome                 String
    caracteristicas_pt   String
    caracteristicas_en   String
    representacao_pt     String
    representacao_en     String
}

// 3. Tabela de Vídeo Aula
model VideoAula {
    id          Int    @id @default(autoincrement())
    conteudo    String
    content     String
    urlMidia    String
    descricao   String
    description String
}

model Curiosidade {
    id          Int    @id @default(autoincrement())
    conteudo    String
    content     String
    curiosidade String
    curiosity   String
}

model Dicas {
    id       Int    @id @default(autoincrement())
    conteudo String
    content  String
    dicas    String
    tips     String
}

model Simulado {
    id              Int    @id @default(autoincrement())
    pergunta        String
    question        String
    opcaoA          String
    optionA         String
    opcaoB          String
    optionB         String
    opcaoC          String
    optionC         String
    opcaoD          String
    optionD         String
    opcaoE          String
    optionE         String
    respostaCorreta String
    correctAnswer   String
    explicacao      String
    explanation     String
}
